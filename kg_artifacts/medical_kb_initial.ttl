@prefix dct: <http://purl.org/dc/terms/> .
@prefix med: <http://medkg.local/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

med: a owl:Ontology ;
    rdfs:label "Medical Knowledge Graph Ontology"@en ;
    dct:created "2026-03-24"^^xsd:date ;
    dct:creator "MedKG Project (Educational)" ;
    dct:description "This ontology defines the conceptual schema for the Medical Knowledge Graph (MedKG). It provides class definitions for medical entities, object property definitions for relationships between them, and equivalence alignments to Wikidata predicates to enable federated querying and knowledge expansion."@en ;
    dct:title "MedKG Ontology"@en ;
    rdfs:comment "An OWL ontology for a medical knowledge base covering diseases, symptoms, treatments, medications, and medical specialties. Constructed from Wikipedia-derived data and aligned to Wikidata."@en ;
    owl:versionInfo "1.0.0" .

