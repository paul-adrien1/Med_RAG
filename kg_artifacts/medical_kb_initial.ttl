med:MedicalSpecialty a owl:Class ;
    rdfs:label "Medical Specialty"@en ;
    rdfs:comment "A branch of medical science in which a physician specializes. Examples: ophthalmologist, endocrinologist, Surgery."@en ;
    rdfs:subClassOf owl:Thing .

med:Treatment a owl:Class ;
    rdfs:label "Treatment"@en ;
    rdfs:comment "A medical procedure or course of action intended to remedy or manage a disease or condition. Examples: dialysis, amputation, insulin replacement therapy, surgery."@en ;
    rdfs:subClassOf owl:Thing .

med:Symptom a owl:Class ;
    rdfs:label "Symptom"@en ;
    rdfs:comment "A physical or mental feature which is regarded as indicating a condition of disease, particularly such a feature that is apparent to the patient. Examples: polydipsia, polyuria, fatigue, blurred vision."@en ;
    rdfs:subClassOf owl:Thing .

med:Medication a owl:Class ;
    rdfs:label "Medication"@en ;
    rdfs:comment "A drug or other preparation for the treatment or prevention of disease. Examples: insulin, metformin, sitagliptin, aspirin."@en ;
    rdfs:subClassOf owl:Thing .

med:Disease a owl:Class ;
    rdfs:label "Disease"@en ;
    rdfs:comment "A disorder of structure or function in a human, animal, or plant, especially one that produces specific signs or symptoms or that affects a specific location. Examples: Diabetes, Hypertension, COVID-19."@en ;
    rdfs:subClassOf owl:Thing .

